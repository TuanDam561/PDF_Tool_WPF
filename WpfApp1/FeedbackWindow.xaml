<Window x:Class="WpfApp1.FeedbackWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gửi phản hồi"
        Height="750"
        Width="560"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Email -->
            <TextBlock Text="Email" FontWeight="SemiBold"/>
            <TextBox Grid.Row="1"
                     Height="32"
                     Margin="0,5,0,12"
                     Text="{Binding Email}" />

            <!-- Name -->
            <TextBlock Grid.Row="2" Text="Tên người dùng" FontWeight="SemiBold"/>
            <TextBox Grid.Row="3"
                     Height="32"
                     Margin="0,5,0,12"
                     Text="{Binding Name}" />

            <!-- Content -->
            <TextBlock Grid.Row="4" Text="Nội dung phản hồi" FontWeight="SemiBold"/>
            <TextBox Grid.Row="5"
                     Height="120"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Text="{Binding Content}" />

            <!-- IMAGE UPLOAD -->
            <GroupBox Grid.Row="6"
          Header="Ảnh đính kèm (tối đa 8 ảnh)"
          Margin="0,15,0,10">

                <StackPanel>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Tải ảnh lên"
                                Width="110"
                                Height="32"
                                Click="UploadImage_Click"/>

                        <Button Content="❌ Xóa tất cả"
                                Width="110"
                                Height="32"
                                Margin="10,0,0,0"
                                Click="ClearImages_Click"/>
                    </StackPanel>

                    <!-- Drag & Drop -->
                    <Border x:Name="ImageDropBorder"
                            Margin="0,10,0,0"
                            Padding="10"
                            Height="220"
                            CornerRadius="8"
                            BorderThickness="1"
                            BorderBrush="#CCCCCC"
                            Background="#FAFAFA"
                            AllowDrop="True"
                            Drop="ImageDropBorder_Drop">

                        <ScrollViewer>
                            <ItemsControl x:Name="ImagesPanel">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <TextBlock Text="Kéo và thả nhiều ảnh • JPG/PNG • ≤ 5MB/ảnh"
                               FontSize="12"
                               Foreground="Gray"
                               Margin="4,6,0,0"/>
                </StackPanel>
            </GroupBox>

            <!-- ACTION BUTTONS -->
            <StackPanel Grid.Row="7"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,10,0,0">
                <Button Content="Gửi phản hồi"
                        Width="130"
                        Height="36"
                        Margin="0,0,10,0"
                        Background="#44db7e"
                        Command="{Binding SubmitCommand}"/>

                <Button Content="Hủy"
                        Width="90"
                        Height="36"
                        Command="{Binding CancelCommand}"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>